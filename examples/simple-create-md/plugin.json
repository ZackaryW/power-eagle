{
  "id": "simple-create-md",
  "name": "Simple Create Markdown",
  "version": "1.0.0",
  "stateVersion": 1,
  "type": "button",
  "keywords": ["example", "files", "markdown", "create"],
  "description": "A minimal Eagle file-creation example that always writes a markdown file.",
  "state": {
    "initial": {
      "fileName": ""
    }
  },
  "ui": {
    "layout": "container",
    "children": [
      {
        "type": "header",
        "title": "Simple Create Markdown",
        "subtitle": "Independent stripped-down file creator: one name input, no cached extensions, shared Eagle-backed create-file surface."
      },
      {
        "type": "row",
        "children": [
          {
            "type": "input",
            "slot": "fileName",
            "placeholder": "File name",
            "flex": 1
          },
          {
            "type": "button",
            "text": "Create File",
            "variant": "primary",
            "onClick": ["ext", "file.createWithContent", [], {
              "fileName": "{{state.fileName}}",
              "extension": "md",
              "title": "Create File",
              "buttonLabel": "Create",
              "missingTitle": "Missing File Name",
              "missingBody": "Enter a file name first.",
              "successTitle": "File Created",
              "successBody": "Created {{state.fileName}}.md",
              "content": "# {{state.fileName}}\n\n"
            }]
          }
        ]
      }
    ]
  }
}